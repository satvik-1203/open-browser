# Port the server listens on.
PORT=3001

# Set to "true" to launch Chrome with --no-sandbox --disable-setuid-sandbox.
# Required when running as a non-root user without a working setuid sandbox
# (e.g. inside Docker) — see the root Dockerfile. Leave unset locally.
PUPPETEER_NO_SANDBOX=false

# Optional: path to a Chrome/Chromium binary to launch instead of the one
# Puppeteer downloads. Read directly by puppeteer, not by our own code.
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium

# --- Recording storage (S3) ---
# Configure these to enable start({ record: true }). When unset, recording is
# rejected with 400 "recording is not configured on this server". Credentials
# live only on the server; clients never send them.
# AWS_REGION=us-east-2
# AWS_S3_BUCKET=browser-replays
# AWS_ACCESS_KEY_ID=...      # or AWS_ACCESS_KEY
# AWS_SECRET_ACCESS_KEY=...  # or AWS_SECRET_KEY
# Optional key prefix, e.g. "recordings/". The browser id + ".mp4" is appended.
# AWS_S3_PREFIX=recordings/
