# Port the backend listens on
PORT=3002

# Browser server (apps/browser-server) — REST calls are proxied here.
BROWSER_SERVER_URL=http://localhost:3001
# Shared secret injected downstream as the `browser-server-bypass-token` header.
BROWSER_SERVER_BYPASS_TOKEN=
# Public, client-reachable base URL of the browser server. Its host is echoed
# into the devtools/ws URLs the browser server returns, so CDP connects directly
# to it (never through the backend). Defaults to BROWSER_SERVER_URL.
BROWSER_SERVER_PUBLIC_URL=http://localhost:3001

# Next.js auth server (apps/dashboard) — validates forwarded user sessions via
# its better-auth /api/auth/get-session endpoint.
AUTH_SERVER_URL=http://localhost:4000

# Postgres — used to validate/revoke API tokens.
DATABASE_URL=

# API token encryption (shared with apps/dashboard — MUST match there).
# 32-byte key: openssl rand -hex 32   (or a base64 32-byte value)
API_TOKEN_ENCRYPTION_KEY=
