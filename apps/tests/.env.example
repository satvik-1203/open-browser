# Credentials + target bucket for the recording test suite (recording.test.ts).
# Copy to `.env` and fill in. The suite is skipped automatically if these are unset.
#
# Standard AWS SDK variable names are used. (AWS_ACCESS_KEY / AWS_SECRET_KEY are
# also accepted as fallbacks for the two key values.)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_S3_BUCKET=

# Optional key prefix for stored recordings (defaults to "recordings-test/").
# AWS_S3_PREFIX=recordings-test/
