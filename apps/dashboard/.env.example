# Database Postgres
DATABASE_URL=

# Resend
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# better-auth
# BETTER_AUTH_SECRET is the signing secret (a.k.a. the JWT secret).
# Generate one with: openssl rand -base64 32
BETTER_AUTH_SECRET=
# Base URL of this app (used for auth callbacks / email links).
BETTER_AUTH_URL=http://localhost:4000

# API token encryption (shared with apps/main-backend — MUST match there).
# 32-byte key: openssl rand -hex 32   (or a base64 32-byte value)
API_TOKEN_ENCRYPTION_KEY=

# --- Browser server (apps/browser-server) ---
# Base URL this app calls to drive browsers (REST: start/stop/get/metrics).
BROWSER_SERVER_URL=http://localhost:3001
# The browser server's PUBLIC address. Sent as the Host header when calling it so
# the CDP/ws URLs it returns point clients straight at it (bypassing this app).
# In production set this to the browser server's externally reachable URL.
BROWSER_SERVER_PUBLIC_URL=http://localhost:3001
# Shared secret sent on every call to the browser server. MUST equal the browser
# server's BROWSER_SERVER_BYPASS_TOKEN. Leave blank to disable (local dev only).
BROWSER_SERVER_BYPASS_TOKEN=
# Shared secret the browser server presents on this app's /internal/* callbacks
# (session-ended, boot reconcile). MUST equal the browser server's
# BACKEND_CALLBACK_TOKEN. Leave blank to disable (local dev only).
# NOTE: the browser server also needs BACKEND_CALLBACK_URL pointing at this app.
BACKEND_CALLBACK_TOKEN=
